<!doctype html>
<html lang="en">
  <head>
    <!-- Required meta tags -->
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

  <!-- Bootstrap CSS -->
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.0.2/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-EVSTQN3/azprG1Anm3QDgpJLIm9Nao0Yz1ztcQTwFspd3yD65VohhpuuCOmLASjC" crossorigin="anonymous">
  <!-- <link rel="stylesheet" href="/Admin Panel Kelurahan Oetete/src/style/admin.css"> -->
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/twitter-bootstrap/5.1.3/css/bootstrap.min.css" type="text/css">
  <link rel="stylesheet" href="https://cdn.datatables.net/1.12.1/css/dataTables.bootstrap5.min.css">
  <link rel="icon" href="/public/favicon.ico">

  <link rel="stylesheet" href="https://cdn.datatables.net/1.12.1/css/jquery.dataTables.min.css">
    <title>Pengguna</title>
  </head>
  <body>
    <script src="https://code.jquery.com/jquery-3.5.1.js"></script>
    <script src="https://cdn.datatables.net/1.12.1/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/1.12.1/js/dataTables.bootstrap5.min.js"></script>
    <!-- header start -->
    <%- include('header'); -%>
    <!-- header end   -->
    

    <style>
      .nav-link:hover{
        background-color: gray;
      }
      .dtHorizontalVerticalExampleWrapper {
          max-width: 600px;
          margin: 0 auto;
        }
        #dtHorizontalVerticalExample th, td {
          white-space: nowrap;
        }
        table.dataTable thead .sorting:after,
        table.dataTable thead .sorting:before,
        table.dataTable thead .sorting_asc:after,
        table.dataTable thead .sorting_asc:before,
        table.dataTable thead .sorting_asc_disabled:after,
        table.dataTable thead .sorting_asc_disabled:before,
        table.dataTable thead .sorting_desc:after,
        table.dataTable thead .sorting_desc:before,
        table.dataTable thead .sorting_desc_disabled:after,
        table.dataTable thead .sorting_desc_disabled:before {
          bottom: .5em;
        }
    </style>

    <div class="row g-0 mt-5" style="min-height: calc(100vh - 50px);">
      <!-- header start -->
      <%- include('sidebar'); -%>
      <!-- header end   -->
  
      <div class="col-md-10 p-5 pt-5">
        <h3><i class="fa-solid fa-users ms-2"></i>&nbsp&nbspPENGGUNA</h3><hr>
        <!-- <a href="/tambah_data/tambah-data-pengguna" type="button" class="btn btn-primary mb-3 "><i class="fa-solid fa-pen-to-square"></i>Tambah Data Pengguna</a> -->
        <a href="/tambah_data/tambah-data-pengguna" type="button" class="btn btn-primary mb-3 "><i class="fa-solid fa-pen-to-square"></i>Tambah Data</a>
        <!-- First Row -->
        <table id="dtHorizontalVerticalExample" class="table table-striped table-bordered table-sm " cellspacing="0"
          width="100%">
          <thead>
            <tr>
              <th scope="col" class="text-center">No</th>
              <th scope="col" class="text-center">Nama Lengkap</th>
              <th scope="col" class="text-center">Username</th>
              <!-- <th scope="col" class="text-center">Password</th> -->
              <th scope="col" class="text-center">Level</th>
              <!-- <th scope="col" class="text-center">Aksi</th> -->
              <th scope="col" class="text-center">Aksi</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <% var number = 1; %> 
              <% for (let row of rows) {%>
              <td scope="row" class="text-center" ><%= number %></td>
              <td scope="row" class="text-center" ><%= row.nama_lengkap %></td>
              <td scope="row" class="text-center" ><%= row.user_name %></td>
              <!-- <td scope="row" class="text-center" ><%= row.user_password %></td> -->
              <td scope="row" class="text-center" >Administrator</td>
              <td scope="row" class="text-center">
                <button class="border-0" data-bs-toggle="modal" data-bs-target="#exampleModal"  data-json="<%= JSON.stringify(row) %>"><i class="fa-solid fa-users-rectangle bg-primary p-2 text-white rounded" data-toggle="tooltip" title="Detail"></i></button>
                <button class="border-0" data-bs-toggle="modal" data-bs-target="#modalEdit"><i class="fa-solid fa-pen-to-square bg-success p-2 text-white rounded" data-toggle="tooltip" title="Edit"></i></button>
                <!-- <button class="border-0"><i class="fa-solid fa-trash-can bg-danger p-2 text-white rounded" data-toggle="tooltip" title="Delete"></i></button> -->
                <a href="/data/data-pengguna/delete/<%= row.user_id %>"  type="button"><i class="fa-solid fa-trash-can bg-danger p-2 text-white rounded" data-toggle="tooltip" title="Delete"></i></a> 
              </td>
              <% number++; %>
              <%- include('edit-modal-pengguna.ejs'); -%>
            </tr>
            <% }%>
          </tbody>
        </table>
      </div>
    </div>

                  <!-- Modal untuk detail data.  --> 
      <div class="modal fade" id="exampleModal" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered"">
          <div class="modal-content">
            <div class="modal-header">
              <h5 class="modal-title" id="exampleModalLabel">Detail Pengguna</h5>
              <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
                <span aria-hidden="true">&times;</span>
              </button>
            </div>
            <div class="modal-body table-responsive">
              <table class="table table-bordered no-margin">
              <tbody>
                <!-- <tr>
                  <th style="width:50%">Id KK</th>
                  <td>KK010202</td>
                </tr> -->
                
                <tr>
                  <th style="width:50%">Nama Lengkap</th>
                  <td class="nama_lengkap"></td>
                </tr>
                <tr>
                  <th style="width:50%">Username</th>
                  <td class="user_name"></td>
                </tr>
                <tr>
                  <th style="width:50%">User Password</th>
                  <td class="user_password"></td>
                </tr>
                

                
              </tbody>
            </table>


            </div>
            <div class="modal-footer">
              <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
            </div>
          </div>
        </div>
      </div>


        <!-- Modal edit -->

  <div class="modal fade " id="exampleModalEdit" tabindex="-1" aria-labelledby="exampleModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg">
      <form action="" class="form-edit" method="POST">
        <!-- menambah form 🔥🔥🔥🔥🔥🔥 -->
        <div class="modal-content ">
          <div class="modal-header">
            <h5 class="modal-title" id="exampleModalLabelEdit">Edit Data Keluarga</h5>
            <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
          <div class="modal-body table-responsive">
            <table class="table table-bordered no-margin">
              <tbody>
                <tr>
                  <th style="width:50%">Nama Lengkap</th>
                  <td>
                    <!-- menambah target binding berdasarkan atribut name -->
                    <input type="text" name="nama_lengkap" class="form-control" />
                  </td>
                </tr>
                <tr>
                  <th style="width:50%">Username</th>
                  <td>
                    <input type="text" name="user_name" class="form-control" />
                  </td>
                </tr>
                <tr>
                  <th style="width:50%">User Password</th>
                  <td>
                    <input type="password" name="user_password" class="form-control" />
                  </td>
                </tr>
              </tbody>
            </table>


          </div>

          <div class="modal-footer">
            <button type="submit" class="btn btn-primary">Simpan</button>
            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
          </div>
        </div>
    </div>
    </form>
  </div>

  <!-- 🔥🔥🔥🔥 modal pemberitahuan -->
  <% 
    if(typeof sukses != "undefined"){
  %>
  <div class="modal fade modal-pemberitahuan" tabindex="-1" aria-labelledby="exampleModalLabel">
    <div class="modal-dialog modal-dialog-centered">
    <div class=" modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="exampleModalLabel">
          <%= sukses == "true" ? "Berhasil" : "Kesalahan" %>
        </h5>
        <button type="button" class="close" data-bs-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </button>
      </div>
      <div class="modal-body table-responsive">
        <%= pesan || "Terjadi sebuah kesalahan" %>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Tutup</button>
      </div>
    </div>
  </div>
  </div>
  <% 
    }
  %>

      
